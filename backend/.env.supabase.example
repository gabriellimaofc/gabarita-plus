SERVER_PORT=8080
DB_URL=jdbc:postgresql://aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.PROJECT_REF
DB_PASSWORD=CHANGE_ME
JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_CHARACTERS
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=15
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
SEED_ENABLED=true
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY_PLACEHOLDER
SUPABASE_BUCKET_QUESTIONS=question-assets
QUESTION_STORAGE_MODE=supabase
QUESTION_STORAGE_LOCAL_PATH=./storage/questions
